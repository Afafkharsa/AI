<div class="banner">
  <div class="d-flex justify-content-between mb-3 bg-light pt-2 pb-2">
    <h4 class="ms-3">Wikinimous</h4>
    <%= link_to "New article", new_article_path, class: "btn btn-primary new_articl_link me-3" %>
  </div>
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <h1>Edit article</h1>
        <%= simple_form_for(@article) do |f| %>
        <div class="form-input mb-3">
          <%= f.input :title, label: "Title" %>
        </div>
        <div class="form-input mb-3">
          <%= f.input :content, as: :text, label: "Content", input_html:
          { class: "form-control", rows: 10 }  %>
        </div>
        <%= f.button :submit, "Update Article", class: "btn btn-primary" %>
        <div class="d-flex justify-content-left mt-3 gap-2">
          <%= link_to "Show", article_path(@article), class: "show_all" %>
          <span class="text-muted">|</span>
          <%= link_to "Back", articles_path, class: "back_home" %>
        </div>
        <% end %>
    </div>
  </div>
</div>
