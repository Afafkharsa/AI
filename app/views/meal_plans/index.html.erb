<div class="container mt-4 fw_bold">
  <h1 class="text-info"  style= "text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5); ">My meal plans</h1>

  <div class="container">
    <div class="row g-4 text-center">

      <div class="col-md-9">

        <!-- Daily meal plan Section -->
        <div class="container-daily mt-4">
          <h2 style= "text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5); 8">Today's meal plans</h2>
          <div class="d-flex justify-content-start">
            <% @today_meals.each do |meal| %>
              <div class="card col-3 text-bg-light m-2" style="border-radius: 15px 15px 0 0;">
                <div class="card-header">
                  <strong style="font-size: 1.1rem;"><%= meal.date %> - <%= meal.meal_type %></strong>
                </div>
                <div class="card-body mb-1 ">
                  <h5>🍔<strong>
                    <%= link_to meal.meal.capitalize, meal_plan_path(meal),
                    class: "meal-link, font-weight: 600, text-success",
                    style: "text-decoration: none; cursor: pointer; color: inherit;" %>
                    </strong>
                  </h5>
                  <% meal.recipes.each do |recipe| %>
                    <%= link_to recipe.name, meal_plan_recipe_path(meal, recipe),
                    class: "list-group-item list-group-item-action list-group-item-light"
                    %>
                  <% end %>
                </div>
              </div>
              <% end %>
          </div>
        </div>

        <!-- Weekly meal plan Section -->
        <div class="container-weekly mt-4">
          <h2 class="mb-4 text-white" style= "text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);">This week meal plans</h2>
          <div class="d-flex flex-row flex-nowrap overflow-auto pb-3">
            <% @weekly_meals.group_by(&:date).each do |date, day_meals| %>
              <div class="me-3" style="min-width: 280px;">
                <div class="card shadow-sm h-100" style="border-radius: 15px; border: 1px solid #eee; background-color: rgba(255, 255, 255, 0.6) !important;">
                  <div class="card-header bg-transparent text-black text-center py-2" style="border-radius: 15px 15px 0 0;">
                    <strong style="font-size: 1.1rem;"><%= date.strftime("%A, %d %B") %></strong>
                  </div>

                  <div class="card-body bg-transparent">
                    <% day_meals.sort_by { |m| ["Breakfast", "Lunch", "Dinner"].index(m.meal_type) || 99 }.each do |m| %>
                      <div class="meal-item mb-2 border-bottom pb-2">
                        <span class="badge bg-dark-subtle mb-1" style="font-size: 0.7rem;"><%= m.meal_type %></span>
                        <h5 class="m-0">
                          🍔<%= link_to m.meal.capitalize, meal_plan_path(m),
                              class: "text-success", style: "text-decoration: none; font-weight: 600;" %>
                          <!--API recipe show section-->
                            <% if m.recipes.any? %>
                              <% m.recipes.each do |recipe| %>
                              <div>
                                <% link_to recipe.name, meal_plan_path(m), class:"text_primary small",
                                style: "text-decoration: none; font-weight: 500;" %>
                              </div>
                              <% end %>
                            <% end %>
                        </h5>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>

      </div>

      <%# Chatbot and meal plan create %>
      <div class="col-md-3">
        <h2 class="mt-4" style= "text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);">Tools</h2>

        <div class="form-actions text-center mt-3 ">
          <%= link_to chats_path(chat: {status: "Pending", title: "Untitled"}),
          data: { turbo_method: :post },
          class: "card h-100 border-0 shadow-sm p-4 text-decoration-none text-dark bg-white" do %>
            <div class="fs-3">🤖</div>
            <h5 class="fw-bold mt-3">Ask for a recipe</h5>
          <% end %>
        </div>

        <div class="form-actions text-center  mt-3">
          <%= link_to new_meal_plan_path,
          class: "card h-100 border-0 shadow-sm p-4 text-decoration-none text-dark bg-white" do %>
            <div class="fs-3">🗓️</div>
            <h5 class="fw-bold mt-3">Create a New Plan</h5>
          <% end %>
        </div>

      </div>
   </div>
  </div>
</div>
