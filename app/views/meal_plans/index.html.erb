<div class="container">
  <h1>My meal plans</h1>
  <div>
    <h3>Ask the assistant for a meal plan</h3>
  </div>
  <div class="container">

    <h3>Today's meal plans</h3>
    <% @today_meals.each do |meal| %>
      <h4><%= meal.meal %>(<%= meal.date %>)</h4>
      <ul>
        <li>
          Recipes
        </li>
      </ul>
    <% end %>
  </div>


  <div class="container">
  <h3>This week meal plans</h3>

  <% @weekly_meals.each do |meal| %>
    <h4><%= meal.meal %>(<%= meal.date %>)</h4>
    <ul>
      <li>
        Recipes
      </li>
    </ul>
  <% end %>
  </div>

  <div class="form-actions mt-4 text-center">
    <%= link_to "Create a New Plan", new_meal_plan_path, class: "btn btn-success w-100" %>
  </div>
