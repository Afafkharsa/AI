<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="mb-4 text-center">Create a new plan</h2>
      <%= simple_form_for(@meal_plan) do |f| %>
        <%#= f.error_notification %>
        <%#= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

        <div class="form-inputs">
          <%# select_date %>
          <%= f.input :date, as: :date,  html5: true, label: "Select Date" %>

          <%# Meal_type %>
          <%= f.input :meal_type, collection: ["Breakfast", "Lunch", "Dinner", "Snack"],
              prompt: "Select meal type", label: "Meal type" %>

          <%# Meal_name %>
          <%= f.input :meal, label: "Meal", placeholder: "Lasagna" %>
          <%#= f.input :calories, label: "Calories (kcal)", input_html: { min: '0' } %>
          <%= f.input :photo, as: :file, label: "Photo" %>
        </div>

        <div class="form-actions mt-4 text-center">
          <%= f.button :submit, "Submit", class: "btn btn-success w-100" %>
          <%= link_to "Cancel", meal_plans_path, class: "btn btn-outline-secondary w-100 mt-2" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
