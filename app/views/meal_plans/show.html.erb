<div class="container mt-4">
  <%= link_to '← Back', meal_plans_path, class: "btn btn-outline-secondary rounded-4 mb-3" %>
  <div class="card shadow">
    <div class="card-body">
      <h1 class="text-success"><%= @meal_plan.meal %></h1>
      <p><strong>Date:</strong> <%= @meal_plan.date.strftime("%d %B %Y") %></p>
      <hr>

      <% if @meal_plan.recipes.any? %>
        <% @meal_plan.recipes.each do |recipe| %>
          <div class="mb-4">
            <h3>How to cook: <%= recipe.name %></h3>
            <p><strong>Calories:</strong> <%= recipe.calories %> kcal</p>
            <p><strong>Ingredients:</strong> <%= recipe.ingredients %></p>
            <p><strong>Method:</strong></p>
            <div class="p-3 bg-light border rounded">
              <%= recipe.method %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-muted">There are no recipes available for this menu yet.</p>
      <% end %>
    </div>
  </div>
  <div class="d-flex justify-content-center gap-3 ">
    <%= link_to "Edit a Plan", edit_meal_plan_path(@meal_plan), class: "btn btn-success w-50 rounded-4 mt-3 me-2 fs-4" %>
     <%= link_to "Delete a Plan", meal_plan_path(@meal_plan), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger w-50 rounded-4 mt-3 ms-2 fs-4" %>
  </div>

</div>
