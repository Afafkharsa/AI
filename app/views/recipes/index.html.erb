<div class="container mt-4">
  <h1 class="text-success mb-4">🔖 My Recipes</h1>

  <% if @recipes.any? %>
    <div class="row g-4">
      <% @recipes.each do |recipe| %>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100">
            <% if recipe.photo.present? %>
              <%= image_tag recipe.photo, class: "card-img-top", style: "height: 200px; object-fit: cover; border-radius: 12px 12px 0 0;" %>
            <% end %>
            <div class="card-body">
              <h5 class="card-title text-success"><%= recipe.name %></h5>
              <p class="text-muted mb-1">🔥 <%= recipe.calories %> kcal</p>
              <p class="text-muted small"><%= Array(recipe.keywords.split(",")).first(3).join(", ") %></p>
              <%= link_to "View Recipe", recipe_path(recipe), class: "btn btn-outline-success btn-sm rounded-pill" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">No recipes saved yet. Ask the AI for a recipe!</p>
    <%= link_to "Ask AI for a recipe", chats_path, data: { turbo_method: :post }, class: "btn btn-success rounded-pill" %>
  <% end %>
</div>
