<div class="container py-4">
  <div class="d-flex justify-content-start mb-3 mt-3">
    <h2 class="fw-bold"><%= @recipe.name %></h2>

    <%= link_to "", meal_plans_path,
    class: "btn-close link-underline link-underline-opacity-0 m-2 px-4" %>
  </div>

  <p>
    <% @recipe.keywords.to_s.split(",").each do |keyword| %>
      <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2 me-1">
        <%= keyword %>
      </span>
    <% end %>
  </p>

  <p class="text-muted mb-1">
    <i class="fas fa-fire me-1"></i> <%= @recipe.calories %> kcal &nbsp;|&nbsp;
    <i class="fas fa-exclamation-triangle me-1"></i>
    <%= @recipe.allergens.present? ? @recipe.allergens : "No allergens" %>
  </p>


  <h3>Ingredients</h3>
  <ul>
    <% raw = @recipe.ingredients.to_s.strip %>

    <% ingredients =
      if raw.include?("\n")
        raw.split("\n")
      else
        raw.split(/,\s(?=[^,]+ - )/)
      end
    %>

    <% ingredients.each do |ingredient| %>
      <li><%= ingredient.strip %></li>
    <% end %>
  </ul>

  <h3>Method</h3>
  <ol class="mt-2">
    <% @recipe.method.to_s.split("\n").each_with_index do |step, index| %>
      <li> <%= step.strip %> </li>
    <% end %>
  </ol>
</div>
