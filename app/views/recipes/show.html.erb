<div class="container">
  <h2 class="mb-3 mt-3"><%= @recipe.name %></h2>

  <%= link_to "⇠ Go back to meal_plans", meal_plans_path %>

  <h3 class="mt-3">Keywords</h3>
  <p><%= @recipe.keywords %></p>

  <h3>Calories</h3>
  <p><%= @recipe.calories %></p>

  <h3>Allergens</h3>
  <p>
    <%= @recipe.allergens.present? ? @recipe.allergens : "No allergens" %>
  </p>

  <h3>Ingredients</h3>
  <ul>
    <% @recipe.ingredients.split(",").each do |ingredient| %>
      <li><%= ingredient.strip %></li>
    <% end %>
  </ul>

  <h3>Method</h3>
  <p><%= @recipe.method %></p>
</div>
